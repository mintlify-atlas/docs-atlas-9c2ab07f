  "keyFeatures": [
    "Encrypted agent-server communication using AES-GCM",
    "FastAPI-based server with async session management",
    "Configurable traffic evasion (jitter, padding, header randomization)",
    "Docker-based deployment with nginx redirector",
    "Command execution with security controls and blocklists",
    "Built-in telemetry and traffic analysis tools",
    "Network flow analysis and feature extraction",
    "Lab environment safety checks"
  ],
  "publicApiSurface": [
    "server.server_main.beacon - Main beacon endpoint for agent communication",
    "server.api_interface.run_repl - Operator console REPL",
    "agent.beacon.BeaconLoop - Agent beacon loop implementation",
    "agent.executor.execute - Command execution with security controls",
    "common.crypto.encrypt - AES-GCM encryption",
    "common.crypto.decrypt - AES-GCM decryption",
    "common.message_format.pack - Pack and encrypt messages",
    "common.message_format.unpack - Decrypt and unpack messages",
    "evasion.header_randomizer.get_headers - Generate randomized HTTP headers",
    "evasion.sleep_strat.get_sleep_fn - Get jitter sleep function",
    "transport.http_transport.send_beacon - Send HTTP beacon request",
    "telemetry.traffic_capture.start_capture - Start PCAP capture",
    "telemetry.flow_parser.parse_pcap - Parse PCAP files",
    "telemetry.feature_extractor.extract_features - Extract traffic features"
  ]
